{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nWave Framework Validation Schemas",
  "description": "Validation schemas for agent, skill, and prompt file definitions. Version 2.0 (2026-04-22). Adapted for GitHub Copilot.",

  "$defs": {
    "agent_frontmatter": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "name": { "type": "string", "pattern": "^nw-[a-z][a-z0-9-]+(-reviewer)?$" },
        "description": { "type": "string", "minLength": 20, "maxLength": 500 },
        "model": { "type": ["string","array"] },
        "tools": { "type": "array", "items": { "type": "string" } },
        "agents": { "type": "array", "items": { "type": "string", "pattern": "^nw-[a-z][a-z0-9-]+(-reviewer)?$" } },
        "user-invocable": { "type": "boolean", "default": true },
        "disable-model-invocation": { "type": "boolean", "default": false },
        "handoffs": { "type": "array", "items": { "type": "object", "properties": { "agent": { "type": "string" } }, "required": ["agent"] } }
      },
      "additionalProperties": false
    },

    "reviewer_frontmatter": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "name": { "type": "string", "pattern": "^nw-[a-z][a-z0-9-]+-reviewer$" },
        "description": { "type": "string", "minLength": 20, "maxLength": 500 },
        "model": { "type": ["string","array"] },
        "tools": { "type": "array", "items": { "type": "string" } },
        "user-invocable": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },

    "skill_frontmatter": {
      "type": "object",
      "required": ["name","description"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]+$" },
        "description": { "type": "string", "minLength": 10, "maxLength": 1024 },
        "argument-hint": { "type": "string", "maxLength": 200 },
        "user-invocable": { "type": "boolean", "default": true }
      },
      "additionalProperties": false
    },

    "prompt_frontmatter": {
      "type": "object",
      "properties": {
        "description": { "type": "string", "minLength": 20, "maxLength": 500 },
        "name": { "type": "string" },
        "argument-hint": { "type": "string", "maxLength": 200 },
        "agent": { "type": "string" },
        "tools": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },

    "section_patterns": {
      "type": "object",
      "properties": {
        "title": { "type": "string", "const": "^# nw-[a-z][a-z0-9-]+(-reviewer)?$" },
        "persona_paragraph": { "type": "string", "const": "^You are [A-Z][a-z]+" },
        "workflow": { "type": "string", "const": "^## (Workflow|\\d+-Phase|Review Workflow)" },
        "example_item": { "type": "string", "const": "^### Example \\d+:" }
      }
    }
  },

  "validation_rules": {
    "agent_rules": [
      { "id": "A01", "name": "frontmatter_present", "severity": "error" },
      { "id": "A02", "name": "name_matches_filename", "severity": "error" },
      { "id": "A03", "name": "line_count_under_limit", "severity": "warning", "thresholds": { "specialist_max": 400, "reviewer_max": 170 } }
    ],

    "skill_rules": [
      { "id": "S01", "name": "frontmatter_present", "severity": "error" }
    ],

    "prompt_rules": [
      { "id": "P01", "name": "frontmatter_present", "severity": "error" },
      { "id": "P02", "name": "description_present", "severity": "error" },
      { "id": "P10", "name": "no_embedded_workflow", "severity": "warning", "pattern": "^(STEP|Step) \\d+:" }
    ]
  },

  "naming_conventions": {
    "prompt_file": { "pattern": "^nw-[a-z][a-z0-9-]+\\.prompt\\.md$", "directory": ".github/prompts/" }
  },

  "size_limits": {
    "prompt_dispatcher": { "warning": 80, "error": 100 },
    "prompt_orchestrator": { "warning": 200, "error": 300 }
  }
}
